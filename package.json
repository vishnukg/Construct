{
    "name": "construct",
    "version": "0.1.0",
    "description": "A TUI for developer workflow metrics and tooling.",
    "type": "module",
    "bin": {
        "construct": "./dist/cli.js"
    },
    "scripts": {
        "cli": "tsx src/cli/index.tsx",
        "typecheck": "tsc --noEmit",
        "build": "tsup",
        "prebuild": "npm run typecheck",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint src tests",
        "test": "vitest run --coverage"
    },
    "keywords": [
        "developer-productivity",
        "tui",
        "github",
        "metrics"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "ink": "^6.5.0",
        "react": "^19.2.1"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.0.3",
        "@types/react": "^19.2.7",
        "@vitest/coverage-v8": "^4.0.16",
        "eslint": "^10.4.0",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.8.3",
        "tsup": "^8.5.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.59.4",
        "vitest": "^4.0.16"
    }
}
